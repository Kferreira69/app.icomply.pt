# ─────────────────────────────────────────────────────────────────────────────
# iComply — Staging Environment Variables
# Copy to .env.staging and fill in real values on the VPS
# ─────────────────────────────────────────────────────────────────────────────

# Staging domain (do NOT include https:// or trailing slash)
STAGING_DOMAIN=staging.icomply.pt

# ── PostgreSQL ────────────────────────────────────────────────
DB_USER=icomply_staging
DB_PASSWORD=CHANGE_ME_staging_db_password
DB_NAME=icomply_staging

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_staging_password

# ── MinIO (S3-compatible storage) ─────────────────────────────
MINIO_USER=icomply_staging
MINIO_PASSWORD=CHANGE_ME_minio_staging_password
S3_BUCKET=icomply-staging-evidence
S3_REGION=eu-west-1

# ── JWT (generate with: openssl rand -base64 64) ──────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP (optional for staging — leave blank to disable emails) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=staging@icomply.pt
