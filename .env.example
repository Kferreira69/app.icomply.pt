# ─────────────────────────────────────────────
# iComply MVP — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env files to git (they're in .gitignore)
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
# These MUST be set — docker-compose will error otherwise
POSTGRES_USER=icomply
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_min16chars
POSTGRES_DB=icomply_db

# ── MinIO ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min16chars

# ── Sentry monitoring (optional) ─────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── App ──────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_NAME=iComply
APP_URL=http://localhost:3001

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://icomply:icomply_secret@localhost:5432/icomply_db

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_super_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_me_refresh_secret_also_long
JWT_REFRESH_EXPIRES_IN=7d

# ── S3 / MinIO (local) ───────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=icomply-evidence
S3_REGION=eu-west-1
S3_FORCE_PATH_STYLE=true

# ── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@icomply.pt
SMTP_PASS=smtp_password
SMTP_FROM="iComply <noreply@icomply.pt>"

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=iComply
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Feature flags ────────────────────────────
ENABLE_SWAGGER=true
ENABLE_AUDIT_LOG=true
