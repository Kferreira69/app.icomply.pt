{
  "name": "icomply-backend",
  "version": "1.0.0",
  "description": "iComply Compliance Operating System — NestJS API",
  "author": "Contemporary Constellation",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "seed": "ts-node --transpile-only --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.4",
    "@nestjs/passport": "^11.0.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.3",
    "@sentry/node": "^10.64.0",
    "argon2": "^0.41.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "multer": "^2.0.0",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.22.0",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "overrides": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "picomatch": "^4.0.2",
    "lodash": "^4.17.21",
    "glob": "^11.0.0",
    "tar": "^7.5.19",
    "tmp": "^0.2.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/common": "^11.1.28",
