  aiSystem        AiSystem?    @relation(fields: [aiSystemId], references: [id])
  title           String
  description     String
  category        AiRiskCategory  @default(OTHER)
  likelihood      Int             @default(3) // 1-5
  impact          Int             @default(3) // 1-5
  riskScore       Int             // likelihood * impact
  residualScore   Int?
  status          String          @default("IDENTIFIED") // IDENTIFIED, MITIGATING, MITIGATED, ACCEPTED, CLOSED
  mitigationPlan  String?
  owner           String?
  dueDate         DateTime?
  reviewDate      DateTime?
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
