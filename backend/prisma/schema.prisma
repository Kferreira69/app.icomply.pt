// ─────────────────────────────────────────────────────────────
// iComply — Prisma Schema  (Phase 1 MVP)
// Owner: Contemporary Constellation
// ─────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COMPLIANCE_MANAGER
  CONSULTANT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLikelihood {
  RARE        // 1
  UNLIKELY    // 2
  POSSIBLE    // 3
  LIKELY      // 4
  ALMOST_CERTAIN // 5
}

enum RiskImpact {
  NEGLIGIBLE  // 1
  MINOR       // 2
  MODERATE    // 3
  MAJOR       // 4
  CATASTROPHIC // 5
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATED
  ACCEPTED
  CLOSED
}

enum EvidenceStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AuditType {
  INTERNAL
  EXTERNAL
  CERTIFICATION
  SURVEILLANCE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FindingSeverity {
  OBSERVATION
  MINOR
  MAJOR
  CRITICAL
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED
  CLOSED
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  OVERDUE
  CANCELLED
}

enum ControlStatus {
  NOT_APPLICABLE
  NOT_IMPLEMENTED
  PARTIALLY_IMPLEMENTED
  IMPLEMENTED
  VERIFIED
}

enum NotificationType {
  // Tasks
  TASK_ASSIGNED
  TASK_DUE_SOON       // 3 days before due date
  TASK_OVERDUE
  TASK_COMPLETED
  // Risks
  RISK_HIGH           // risk scored HIGH or CRITICAL
  RISK_STATUS_CHANGED
  // CAPA
  CAPA_ASSIGNED
  CAPA_DUE_SOON
  CAPA_OVERDUE
  // Audits
  AUDIT_SCHEDULED
  AUDIT_FINDING_ADDED
  // Evidence
  EVIDENCE_EXPIRING   // 30 days before expiry
  EVIDENCE_REJECTED
  // Policies
  POLICY_REVIEW
  // Vendors
  VENDOR_EXPIRY
  VENDOR_ASSESSMENT_COMPLETED
  // System
  USER_INVITED
  SYSTEM
}

enum DiagnosticStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ReportType {
  COMPLIANCE_SUMMARY
  RISK_REGISTER
  AUDIT_REPORT
  TASK_STATUS
  EVIDENCE_GAP
  EXECUTIVE_DASHBOARD
}

enum ReportFormat {
  PDF
  EXCEL
  JSON
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PolicyStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

enum PolicyCategory {
  INFORMATION_SECURITY
  DATA_PROTECTION
  BUSINESS_CONTINUITY
  HUMAN_RESOURCES
  PHYSICAL_SECURITY
  ACCESS_CONTROL
  INCIDENT_MANAGEMENT
  SUPPLIER_MANAGEMENT
  COMPLIANCE
  OPERATIONAL
  OTHER
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTERESTS
  PUBLIC_TASK
  LEGITIMATE_INTERESTS
}

enum ProcessingActivityStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
}

enum DpiaStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
}

enum DpiaOutcome {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK_PROCEED
  HIGH_RISK_CONSULT_DPA
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachStatus {
  IDENTIFIED
  ASSESSING
  NOTIFYING
  CLOSED
}

// ─── Organizations (Tenants) ──────────────────────────────────

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  // ── Extended profile ──────────────────────────────────────
  legalName    String?           // Nome legal completo
  tradeName    String?           // Nome comercial
  industry     String?           // e.g. TECHNOLOGY, FINANCIAL_SERVICES, HEALTHCARE
  size         String?           // MICRO, SMALL, MEDIUM, LARGE, ENTERPRISE
  country      String   @default("PT")
  vatNumber    String?           // NIF/VAT
  employeeCount  Int?
  annualRevenue  Decimal? @db.Decimal(15,2)
  groupName    String?           // Grupo empresarial
  address      String?
  logoUrl      String?
  website      String?
  phone        String?
  billingEmail String?
  plan         String   @default("FREE") // FREE, STARTER, PROFESSIONAL, ENTERPRISE
  maxUsers     Int      @default(5)
  isActive     Boolean  @default(true)
  aiProvider   String   @default("AUTO") // ANTHROPIC, OPENAI, AUTO
  aiModel      String?  // e.g. "claude-sonnet-4-5", "gpt-4o", "gpt-4o-mini"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // ── Extended profile relations ────────────────────────────
  orgAddresses    OrgAddress[]
  orgContacts     OrgContact[]
  reportSchedules ReportSchedule[]
  webhooks        Webhook[]
  orgRoles        OrgRole[]
  aiCreditUsage   AiCreditUsage[]
  raciAssignments RaciAssignment[]
  ssoConfig       SsoConfig?
  // Multi-entity
  parentId        String?
  parent          Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children        Organization[] @relation("OrgHierarchy")
  // Sprint Premium
  doraRegisterEntries       DoraRegisterEntry[]
  nis2IncidentNotifications Nis2IncidentNotification[]
  auditorSessions           AuditorSession[]
  managementBodyMembers     ManagementBodyMember[]
  boardReports              BoardReport[]
  hubMembershipsAsHub       ClientHubMembership[] @relation("HubConsultancy")
  hubMembershipsAsClient    ClientHubMembership[] @relation("HubClient")

  users             User[]
  projects          Project[]
  risks             Risk[]
  diagnosticRuns    DiagnosticRun[]
  auditLogs         AuditLog[]
  reports           Report[]
  excelImports      ExcelImport[]
  audits            Audit[]
  notifications     Notification[]
  policies          Policy[]
  dataProcessingActivities DataProcessingActivity[]
  dpias             Dpia[]
  breachNotifications BreachNotification[]
  nis2Assessments   Nis2Assessment[]
  vendors           Vendor[]
  soaControls       SoaControl[]
  doraIncidents     DoraIncident[]
  doraTests         DoraTest[]
  whistleblowReports     WhistleblowReport[]
  codesOfConduct         CodeOfConduct[]
  whistleblowTrainings   WhistleblowTraining[]
  trustCenter            TrustCenterSettings?
  license                License?
  unifiedControls        UnifiedControl[]
  regulatoryObligations  RegulatoryObligation[]
  hrSalaryBands          HrSalaryBand[]
  hrShstIncidents        HrShstIncident[]
  hrContracts            HrContract[]
  hrRemoteWorkers        HrRemoteWorker[]
  hrTrainings            HrTraining[]
  aiSystems              AiSystem[]
  aiRisks                AiRisk[]
  aiImpactAssessments    AiImpactAssessment[]
  ai42001Controls        Ai42001Control[]
  esgReports             EsgReport[]
  esgMetrics             EsgMetric[]
  dsarRequests           DataSubjectRequest[]
  consentRecords         ConsentRecord[]
  bcpPlans               BcpPlan[]
  bcpTests               BcpTest[]
  itsmChangeRequests     ItsmChangeRequest[]
  itsmIncidents          ItsmIncident[]
  itsmProblems           ItsmProblem[]
  amlCases               AmlCase[]
  amlScreenings          AmlScreening[]
  amlPolicies            AmlPolicy[]
  iso27701Controls       Iso27701Control[]
  soc2Criteria           Soc2Criterion[]

  // Wave 3
  cisControls         CisControl[]           @relation("CisControls")
  tisaxAssessments    TisaxAssessment[]      @relation("TisaxAssessments")
  tisaxControls       TisaxControl[]         @relation("TisaxControls")
  antiBriberyControls AntiBriberyControl[]   @relation("AntiBriberyControls")
  workforceCompliance WorkforceCompliance[]  @relation("WorkforceCompliance")
  qualityControls     QualityControl[]       @relation("QualityControls")
  capaRecords         CapaRecord[]           @relation("CapaRecords")
  regulatoryChanges   RegulatoryChange[]     @relation("RegulatoryChanges")
  calendarItems       ComplianceCalendarItem[] @relation("CalendarItems")

  @@map("organizations")
}

// ─── Trust Center ─────────────────────────────────────────────

model TrustCenterSettings {
  id               String   @id @default(uuid())
  organizationId   String   @unique
  isPublic         Boolean  @default(false)
  showFrameworks   Boolean  @default(true)
  showEvidence     Boolean  @default(true)
  showAudits       Boolean  @default(true)
  showPolicies     Boolean  @default(true)
  showVendors      Boolean  @default(false)
  showRisks        Boolean  @default(false)
  customMessage    String?
  contactEmail     String?
  customTitle      String?
  logoUrl          String?
  accentColor      String   @default("#2563eb")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])

  @@map("trust_center_settings")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?
  firstName        String
  lastName         String
  role             UserRole   @default(VIEWER)
  status           UserStatus @default(INVITED)
  avatarUrl        String?
  phone            String?
  inviteToken      String?    @unique
  inviteExpiresAt  DateTime?
  passwordResetToken String?  @unique
  passwordResetExpiresAt DateTime?
  lastLoginAt      DateTime?
  // 2FA / TOTP
  totpSecret       String?
  totpEnabled      Boolean    @default(false)
  totpVerifiedAt   DateTime?
  organizationId   String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])
  assignedTasks    Task[]       @relation("TaskAssignee")
  createdTasks     Task[]       @relation("TaskCreator")
  taskComments     TaskComment[]
  risks            Risk[]
  evidences        Evidence[]
  auditLogs        AuditLog[]
  capaItems        Capa[]       @relation("CapaAssignee")
  createdCapas     Capa[]       @relation("CapaCreator")
  notifications    Notification[]
  auditParticipations AuditParticipant[]
  ownedPolicies    Policy[]     @relation("PolicyOwner")
  approvedPolicies Policy[]     @relation("PolicyApprover")
  policyVersions   PolicyVersion[]
  policyAcknowledgments PolicyAcknowledgment[]
  controlledActivities DataProcessingActivity[] @relation("ProcessingActivityController")
  ownedDpias       Dpia[]       @relation("DpiaOwner")
  ownedBreaches    BreachNotification[] @relation("BreachNotificationOwner")
  nis2Assessments       Nis2Assessment[]   @relation("Nis2Responsible")
  vendorAssessments     VendorAssessment[] @relation("VendorAssessor")
  doraIncidentsReported DoraIncident[]     @relation("DoraIncidentReporter")
  doraTestsConducted    DoraTest[]         @relation("DoraTestConductor")
  whistleblowAssigned   WhistleblowReport[] @relation("WhistleblowAssignee")
  whistleblowTimeline   WhistleblowTimeline[]
  codeOfConductAcks     CodeOfConductAck[]
  trainingAttendances   WhistleblowTrainingAttendee[]
  permissions           UserPermission[]
  notificationPrefs     NotificationPreference[]
  hrContracts           HrContract[]
  hrRemoteWorkerProfile HrRemoteWorker[]
  hrTrainingEnrollments HrTrainingEnrollment[]
  aiImpactAssessments   AiImpactAssessment[]
  dsarHandled            DataSubjectRequest[] @relation("DsarHandler")
  bcpPlansOwned          BcpPlan[]            @relation("BcpOwner")
  changeRequestsMade     ItsmChangeRequest[]  @relation("ChangeRequester")
  changeRequestsApproved ItsmChangeRequest[]  @relation("ChangeApprover")
  incidentsReported      ItsmIncident[]       @relation("IncidentReporter")
  incidentsAssigned      ItsmIncident[]       @relation("IncidentAssignee")
  problemsOwned          ItsmProblem[]        @relation("ProblemOwner")
  amlCasesAssigned       AmlCase[]            @relation("AmlAssignee")
  soc2Responsibilities   Soc2Criterion[]      @relation("Soc2Responsible")

  // Wave 3
  cisControlsOwned         CisControl[]           @relation("CisResponsible")
  tisaxControlsOwned       TisaxControl[]         @relation("TisaxResponsible")
  antiBriberyControlsOwned AntiBriberyControl[]   @relation("AntiBriberyResponsible")
  workforceControlsOwned   WorkforceCompliance[]  @relation("WorkforceResponsible")
  qualityControlsOwned     QualityControl[]       @relation("QualityResponsible")
  capaRecordsOwned         CapaRecord[]           @relation("CapaResponsible")
  capaRecordsVerified      CapaRecord[]           @relation("CapaVerifier")
  regChangesOwned          RegulatoryChange[]     @relation("RegChangeResponsible")
  calendarItemsOwned       ComplianceCalendarItem[] @relation("CalendarResponsible")
  nis2IncidentsResponsible Nis2IncidentNotification[] @relation("Nis2IncidentResponsible")
  raciAssignments          RaciAssignment[]

  @@map("users")
}

// ─── User Permissions ─────────────────────────────────────────
// Granular per-module access control (0=none, 1=read, 2=full)
// ADMIN role always bypasses these; they apply to non-admin users.

model UserPermission {
  id     String @id @default(uuid())
  userId String
  module String  // dashboard | diagnostic | projects | tasks | risks |
                 // evidence | audits | capa | reports | policies | gdpr |
                 // nis2 | dora | denuncias | vendors | soa | excelImport |
                 // aiAssistant | trustCenter | users | settings | translations
  level  Int    @default(1)  // 0=NONE 1=READ 2=FULL

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@map("user_permissions")
}

// ─── Frameworks ───────────────────────────────────────────────

model Framework {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique  // e.g. ISO_27001, GDPR, NIS2, RGPC
  version     String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements Requirement[]
  controls     Control[]
  templates    Template[]
  projects     Project[]
  diagnosticQuestions DiagnosticQuestion[]
  policies     Policy[]

  @@map("frameworks")
}

// ─── Requirements (framework clauses) ────────────────────────

model Requirement {
  id           String   @id @default(uuid())
  frameworkId  String
  code         String   // e.g. "6.1.2", "Art. 5"
  title        String
  description  String?
  category     String?
  mandatory    Boolean  @default(true)
  sortOrder    Int      @default(0)
  parentId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  framework    Framework    @relation(fields: [frameworkId], references: [id])
  parent       Requirement? @relation("RequirementHierarchy", fields: [parentId], references: [id])
  children     Requirement[] @relation("RequirementHierarchy")
  controls     Control[]

  @@unique([frameworkId, code])
  @@map("requirements")
}

// ─── Controls ─────────────────────────────────────────────────

model Control {
  id            String        @id @default(uuid())
  frameworkId   String
  requirementId String?
  code          String
  title         String
  description   String?
  guidance      String?
  category      String?
  status        ControlStatus @default(NOT_IMPLEMENTED)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  framework    Framework    @relation(fields: [frameworkId], references: [id])
  requirement  Requirement? @relation(fields: [requirementId], references: [id])
  tasks        Task[]
  evidences    Evidence[]
  findings     Finding[]

  @@unique([frameworkId, code])
  @@map("controls")
}

// ─── Templates ───────────────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  frameworkId String
  name        String
  description String?
  type        String   // PROJECT, TASK_LIST, REPORT, etc.
  content     Json     // template structure
  isPublic    Boolean  @default(true)
  version     String   @default("1.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  framework   Framework @relation(fields: [frameworkId], references: [id])
  projects    Project[]

  @@map("templates")
}

// ─── Diagnostic Engine ────────────────────────────────────────

model DiagnosticQuestion {
  id           String   @id @default(uuid())
  frameworkId  String?
  code         String   @unique
  question     String
  description  String?
  category     String
  type         String   // SINGLE_CHOICE, MULTIPLE_CHOICE, SCALE, TEXT, BOOLEAN
  options      Json?    // [{value, label, weight}]
  weight       Float    @default(1.0)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  conditionalOn String? // JSON: {questionCode, value}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  framework    Framework? @relation(fields: [frameworkId], references: [id])
  answers      DiagnosticAnswer[]

  @@map("diagnostic_questions")
}

model DiagnosticRun {
  id              String           @id @default(uuid())
  organizationId  String
  status          DiagnosticStatus @default(IN_PROGRESS)
  answers         DiagnosticAnswer[]
  recommendations Json?            // [{frameworkId, score, priority, reason}]
  sector          String?
  country         String?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  projects     Project[]

  @@map("diagnostic_runs")
}

model DiagnosticAnswer {
  id          String   @id @default(uuid())
  runId       String
  questionId  String
  value       Json     // the answer value(s)
  score       Float?
  createdAt   DateTime @default(now())

  run         DiagnosticRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  question    DiagnosticQuestion @relation(fields: [questionId], references: [id])

  @@unique([runId, questionId])
  @@map("diagnostic_answers")
}

// ─── Projects ─────────────────────────────────────────────────

model Project {
  id               String        @id @default(uuid())
  organizationId   String
  frameworkId      String
  templateId       String?
  diagnosticRunId  String?
  name             String
  description      String?
  status           ProjectStatus @default(DRAFT)
  complianceScore  Float?        // 0-100
  startDate        DateTime?
  targetDate       DateTime?
  completedAt      DateTime?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  framework     Framework     @relation(fields: [frameworkId], references: [id])
  template      Template?     @relation(fields: [templateId], references: [id])
  diagnosticRun DiagnosticRun? @relation(fields: [diagnosticRunId], references: [id])
  tasks         Task[]
  risks         Risk[]
  audits        Audit[]
  evidences     Evidence[]
  reports       Report[]

  @@map("projects")
}

// ─── Tasks ────────────────────────────────────────────────────

model Task {
  id             String       @id @default(uuid())
  projectId      String
  controlId      String?
  assigneeId     String?
  createdById    String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?
  tags           String[]
  sortOrder      Int          @default(0)
  parentId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  control    Control? @relation(fields: [controlId], references: [id])
  assignee   User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy  User     @relation("TaskCreator", fields: [createdById], references: [id])
  parent     Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  subtasks   Task[]   @relation("TaskHierarchy")
  evidences  Evidence[]
  comments   TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

// ─── Risks ────────────────────────────────────────────────────

model Risk {
  id              String         @id @default(uuid())
  organizationId  String
  projectId       String?
  ownerId         String?
  title           String
  description     String?
  category        String?
  likelihood      RiskLikelihood @default(POSSIBLE)
  impact          RiskImpact     @default(MODERATE)
  inherentScore   Int            // likelihood * impact (1-25)
  residualScore   Int?           // after controls
  status          RiskStatus     @default(IDENTIFIED)
  // Treatment plan
  treatmentType   String?        // MITIGATE, ACCEPT, TRANSFER, AVOID
  treatmentPlan   String?        // detailed treatment plan (richer than old mitigationPlan)
  mitigationPlan  String?        // kept for backward compat
  treatmentStatus String?        // PLANNED, IN_PROGRESS, COMPLETED
  treatmentOwnerId String?
  treatmentDueDate DateTime?
  treatmentCompletedAt DateTime?
  // Acceptance
  acceptancePlan   String?
  acceptedAt       DateTime?
  acceptedById     String?
  acceptanceRationale String?
  // Risk appetite
  riskAppetite    String?        // ABOVE, AT, BELOW (vs org appetite)
  dueDate         DateTime?
  reviewDate      DateTime?
  closedAt        DateTime?
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  owner        User?        @relation(fields: [ownerId], references: [id])
  evidences    Evidence[]
  unifiedControlLinks UnifiedControlRisk[]
  snapshots    RiskSnapshot[]

  @@map("risks")
}

// ── Risk history snapshots ─────────────────────────────────────

model RiskSnapshot {
  id            String   @id @default(uuid())
  riskId        String
  risk          Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  inherentScore Int
  residualScore Int?
  status        String
  treatmentType String?
  treatmentStatus String?
  likelihood    String
  impact        String
  capturedAt    DateTime @default(now())
  capturedById  String?

  @@index([riskId, capturedAt])
  @@map("risk_snapshots")
}

// ─── Evidence ─────────────────────────────────────────────────

model Evidence {
  id              String         @id @default(uuid())
  projectId       String?
  taskId          String?
  controlId       String?
  riskId          String?
  uploadedById    String
  title           String
  description     String?
  fileName        String
  fileSize        Int
  mimeType        String
  s3Key           String         // S3 object key
  s3Url           String?        // pre-signed or public URL
  version         Int            @default(1)
  previousVersion String?        // previous evidence id
  status          EvidenceStatus @default(PENDING)
  expiresAt       DateTime?
  reviewedAt      DateTime?
  tags            String[]
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project    Project?  @relation(fields: [projectId], references: [id])
  task       Task?     @relation(fields: [taskId], references: [id])
  control    Control?  @relation(fields: [controlId], references: [id])
  risk       Risk?     @relation(fields: [riskId], references: [id])
  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  unifiedControlLinks UnifiedControlEvidence[]
  versions   EvidenceVersion[]

  @@map("evidences")
}

// ─── Audits ───────────────────────────────────────────────────

model Audit {
  id             String      @id @default(uuid())
  organizationId String
  projectId      String?
  title          String
  type           AuditType   @default(INTERNAL)
  status         AuditStatus @default(PLANNED)
  scope          String?
  objectives     String?
  startDate      DateTime?
  endDate        DateTime?
  completedAt    DateTime?
  leadAuditor    String?
  summary        String?
  score          Float?      // 0-100
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  project      Project?          @relation(fields: [projectId], references: [id])
  participants AuditParticipant[]
  findings     Finding[]

  @@map("audits")
}

model AuditParticipant {
  id        String @id @default(uuid())
  auditId   String
  userId    String
  role      String // LEAD_AUDITOR, AUDITOR, AUDITEE, OBSERVER

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([auditId, userId])
  @@map("audit_participants")
}

// ─── Findings ─────────────────────────────────────────────────

model Finding {
  id          String          @id @default(uuid())
  auditId     String
  controlId   String?
  title       String
  description String
  severity    FindingSeverity @default(MINOR)
  status      FindingStatus   @default(OPEN)
  evidence    String?
  requirement String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  audit   Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  control Control? @relation(fields: [controlId], references: [id])
  capas   Capa[]

  @@map("findings")
}

// ─── CAPA (Corrective and Preventive Actions) ─────────────────

model Capa {
  id           String     @id @default(uuid())
  findingId    String?
  assigneeId   String?
  createdById  String
  title        String
  description  String
  rootCause    String?
  correctiveAction String?
  preventiveAction String?
  status       CapaStatus @default(OPEN)
  dueDate      DateTime?
  verifiedAt   DateTime?
  closedAt     DateTime?
  evidence     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  finding    Finding? @relation(fields: [findingId], references: [id])
  assignee   User?    @relation("CapaAssignee", fields: [assigneeId], references: [id])
  createdBy  User     @relation("CapaCreator", fields: [createdById], references: [id])

  @@map("capas")
}

// ─── Reports ─────────────────────────────────────────────────

model Report {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String?
  type           ReportType
  format         ReportFormat @default(PDF)
  name           String
  parameters     Json?        // filter params
  s3Key          String?      // generated file
  s3Url          String?
  generatedAt    DateTime?
  status         String       @default("PENDING") // PENDING, READY, FAILED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@map("reports")
}

// ── Scheduled Reports ─────────────────────────────────────────

model ReportSchedule {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  type           ReportType
  format         ReportFormat @default(PDF)
  frequency      String   @default("MONTHLY")  // DAILY, WEEKLY, MONTHLY, QUARTERLY
  recipients     String[] @default([])          // email addresses
  parameters     Json?
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@map("report_schedules")
}

// ─── Excel Imports ───────────────────────────────────────────

model ExcelImport {
  id             String       @id @default(uuid())
  organizationId String
  fileName       String
  fileSize       Int
  s3Key          String
  type           String       // TASKS, RISKS, CONTROLS, GENERIC
  status         ImportStatus @default(PENDING)
  mapping        Json?        // column mapping
  rowsTotal      Int?
  rowsProcessed  Int?
  rowsError      Int?
  errors         Json?
  result         Json?        // summary of what was created
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("excel_imports")
}

// ─── Audit Logs ───────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  action         String   // CREATE, UPDATE, DELETE, LOGIN, EXPORT, etc.
  entity         String   // Organization, User, Project, Risk, etc.
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  organizationId String
  userId         String           // recipient
  type           NotificationType
  title          String
  message        String
  entityType     String?          // "Task" | "Risk" | "Capa" | etc.
  entityId       String?          // uuid of the related entity
  read           Boolean          @default(false)
  readAt         DateTime?
  emailSent      Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([organizationId, createdAt])
  @@map("notifications")
}

// ─── Policies ─────────────────────────────────────────────────

model Policy {
  id             String         @id @default(uuid())
  organizationId String
  title          String
  description    String?
  content        String         @db.Text
  version        String         @default("1.0")
  status         PolicyStatus   @default(DRAFT)
  category       PolicyCategory @default(OTHER)
  frameworkId    String?
  ownerId        String
  approverId     String?
  approvedAt     DateTime?
  effectiveDate  DateTime?
  reviewDate     DateTime?
  expiresAt      DateTime?
  tags           String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization           @relation(fields: [organizationId], references: [id])
  owner           User                   @relation("PolicyOwner", fields: [ownerId], references: [id])
  approver        User?                  @relation("PolicyApprover", fields: [approverId], references: [id])
  framework       Framework?             @relation(fields: [frameworkId], references: [id])
  versions        PolicyVersion[]
  acknowledgments PolicyAcknowledgment[]

  @@index([organizationId, status])
  @@index([organizationId, category])
  @@map("policies")
}

model PolicyVersion {
  id          String   @id @default(uuid())
  policyId    String
  version     String
  content     String   @db.Text
  changeNote  String?
  changedById String
  createdAt   DateTime @default(now())

  policy    Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@map("policy_versions")
}

model PolicyAcknowledgment {
  id             String   @id @default(uuid())
  policyId       String
  userId         String
  policyVersion  String?
  acknowledgedAt DateTime @default(now())
  ipAddress      String?

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([policyId, userId])
  @@map("policy_acknowledgments")
}

// ─── GDPR / Data Protection ────────────────────────────────────

model DataProcessingActivity {
  id                     String                   @id @default(uuid())
  organizationId         String
  name                   String
  purpose                String
  legalBasis             LegalBasis
  dataCategories         String[]                 @default([])
  dataSubjects           String[]                 @default([])
  recipients             String[]                 @default([])
  internationalTransfers Boolean                  @default(false)
  transferCountries      String[]                 @default([])
  transferSafeguards     String?
  retentionPeriod        String
  retentionJustification String?
  technicalMeasures      String[]                 @default([])
  organizationalMeasures String[]                 @default([])
  dpoConsulted           Boolean                  @default(false)
  processorName          String?
  processorCountry       String?
  status                 ProcessingActivityStatus @default(ACTIVE)
  controllerId           String
  reviewDate             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  controller   User         @relation("ProcessingActivityController", fields: [controllerId], references: [id])
