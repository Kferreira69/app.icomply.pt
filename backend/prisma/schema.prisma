  notes         String?

  training      WhistleblowTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id])

  @@unique([trainingId, userId])
  @@index([trainingId])
  @@map("whistleblow_training_attendees")
