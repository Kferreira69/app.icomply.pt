// ─── DORA — Digital Operational Resilience Act ────────────────

enum DoraIncidentSeverity {
  MINOR
  SIGNIFICANT
  MAJOR
}

enum DoraIncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum DoraIncidentCategory {
  AVAILABILITY
  AUTHENTICITY
  INTEGRITY
  CONFIDENTIALITY
  CONTINUITY
}

enum DoraTestType {
  VULNERABILITY_ASSESSMENT
  PENETRATION_TEST
  TLPT
  BUSINESS_CONTINUITY
  SCENARIO_BASED
  GAP_ANALYSIS
