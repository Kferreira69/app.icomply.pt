// ─────────────────────────────────────────────────────────────
// UNIFIED CONTROL FRAMEWORK ENGINE
// Core world-class architecture: control-centric, cross-framework
// One control → many frameworks → one evidence base
// ─────────────────────────────────────────────────────────────

// Governance domains (top-level organizational construct)
enum GovernanceDomain {
  SECURITY           // ISO 27001, NIS2, DORA, SOC2, CIS
  PRIVACY            // GDPR, ISO 27701, ePrivacy
  AI_GOVERNANCE      // EU AI Act, ISO 42001, NIST AI RMF
  ETHICS_SPEAKUP     // RGPC, Whistleblowing, Code of Conduct
  WORKFORCE          // HR Compliance, Pay Transparency, SHST
  THIRD_PARTY        // Vendor Risk, TPRM, Outsourcing
  AUDIT_ASSURANCE    // Internal Audit, CAPA, Continuous Monitoring
  REGULATORY_CHANGE  // Horizon scanning, Obligation tracking
  AML_FINANCIAL      // AML/KYC, Anti-Bribery, Sanctions
  ESG                // CSRD, ESG Reporting, Sustainability
  DATA_RECORDS       // Retention, Data Lifecycle, Records Management
  RESILIENCE         // BCP, ISO 22301, Crisis Management
  QUALITY            // ISO 9001, Process Governance
  CORPORATE          // Policies, Board Governance, Delegations
}

// Master control library — framework-agnostic, cross-mapped
model UnifiedControl {
  id             String           @id @default(uuid())
  organizationId String
  domain         GovernanceDomain
  controlId      String           // e.g. "PAM-001", "DATA-003"
  title          String
  description    String?
  objective      String?          // What this control achieves

  // Cross-framework mapping: which standards require this control
  // e.g. ["ISO27001:A.8.1", "NIS2:Art21.2a", "DORA:Art9", "SOC2:CC6.1"]
  frameworkMappings String[]      @default([])

  // Implementation
  status         String           @default("NOT_STARTED")
  // NOT_STARTED | PLANNED | IN_PROGRESS | IMPLEMENTED | VERIFIED | NOT_APPLICABLE
  implementationNotes String?
  automationLevel String?         // MANUAL | PARTIAL | AUTOMATED
  testingFrequency String?        // CONTINUOUS | MONTHLY | QUARTERLY | ANNUAL
  owner          String?
  targetDate     DateTime?
  lastTestedAt   DateTime?
  nextReviewAt   DateTime?

  // Justification if N/A
  applicable     Boolean          @default(true)
  naJustification String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id])
  evidenceLinks  UnifiedControlEvidence[]
  riskLinks      UnifiedControlRisk[]

  @@unique([organizationId, controlId])
  @@index([organizationId, domain])
  @@index([organizationId, status])
  @@map("unified_controls")
}

// Evidence reuse: one piece of evidence can satisfy many controls
model UnifiedControlEvidence {
  id          String        @id @default(uuid())
  controlId   String
  evidenceId  String
  notes       String?
  linkedAt    DateTime      @default(now())
  linkedBy    String?

  control     UnifiedControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  evidence    Evidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([controlId, evidenceId])
  @@map("unified_control_evidences")
}

// Risk linkage: risks map to controls (not to frameworks)
model UnifiedControlRisk {
  id        String         @id @default(uuid())
  controlId String
  riskId    String
  notes     String?
  linkedAt  DateTime       @default(now())

  control   UnifiedControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  risk      Risk           @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([controlId, riskId])
  @@map("unified_control_risks")
}

// Regulatory obligation tracking — horizon scanning
model RegulatoryObligation {
  id              String   @id @default(uuid())
  organizationId  String
  domain          GovernanceDomain
  regulation      String   // e.g. "EU AI Act", "NIS2", "CSRD"
  jurisdiction    String   @default("EU") // EU, PT, ES, FR, EN, ...
  obligationCode  String?  // e.g. "Art.21(2)(a)"
  title           String
  description     String?
  effectiveDate   DateTime?
  complianceDate  DateTime? // deadline for compliance
  status          String   @default("MONITORING")
  // MONITORING | IN_PROGRESS | COMPLIANT | NON_COMPLIANT | NOT_APPLICABLE
  priority        String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  sourceUrl       String?
  internalNotes   String?
  ownerId         String?
  lastUpdatedBy   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, domain])
  @@index([organizationId, status])
  @@index([organizationId, complianceDate])
  @@map("regulatory_obligations")
}

// ─────────────────────────────────────────────────────────────
// PONTO 16 — Licensing Management
// Backoffice exclusivo Contemporary Constellation
// ─────────────────────────────────────────────────────────────

model License {
  id             String   @id @default(uuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           String   @default("FREE")    // FREE, STARTER, PROFESSIONAL, ENTERPRISE, CUSTOM
  status         String   @default("ACTIVE")  // ACTIVE, TRIAL, SUSPENDED, CANCELLED, PAST_DUE, EXPIRED
  billingCycle   String   @default("MONTHLY") // MONTHLY, QUARTERLY, ANNUAL, MULTI_YEAR
  trialEndsAt    DateTime?
  startDate      DateTime @default(now())
  endDate        DateTime?
  nextBillingDate DateTime?
  autoRenew      Boolean  @default(true)
  gracePeriodDays Int     @default(7)
  // Stripe
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  stripePaymentMethodId String?
  stripePriceId         String?
  // Moloni
  moloniClientId String?
  moloniCustomerId String?
  // AI config
  aiProvider     String   @default("AUTO")
  aiModel        String?
  // Limits
  maxUsers       Int      @default(5)
  maxStorageGb   Int      @default(5)
  maxAiCredits   Int      @default(100)
  maxApiCalls    Int      @default(0)
  // Contacts
  contactName    String?
  contactEmail   String?
  notes          String?
  // Lifecycle timestamps
  suspendedAt          DateTime?
  cancelledAt          DateTime?
  renewalReminderSentAt DateTime?
  // Relations
  modules        LicenseModule[]
  invoices       LicenseInvoice[]
  addons         LicenseAddon[]
  events         SubscriptionEvent[]
  featureFlags   FeatureFlag[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("licenses")
}

model LicenseModule {
  id           String   @id @default(uuid())
  licenseId    String
  license      License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  module       String   // gdpr, nis2, dora, hr_compliance, ai_governance, whistleblow, vendors, soa, etc.
  enabled      Boolean  @default(true)
  monthlyPrice Decimal  @default(0) @db.Decimal(10,2)
  annualPrice  Decimal  @default(0) @db.Decimal(10,2)
  submodules   String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([licenseId, module])
  @@map("license_modules")
}

model LicenseInvoice {
  id          String   @id @default(uuid())
  licenseId   String
  license     License  @relation(fields: [licenseId], references: [id])
  // Moloni
  moloniId    String?
  moloniDocNo String?
  moloniReceiptId  String?
  moloniReceiptNo  String?
  // Stripe
  stripeInvoiceId       String?
  stripePaymentIntentId String?
  // Amounts
  amount      Decimal  @db.Decimal(10,2)
  taxRate     Decimal  @default(23) @db.Decimal(5,2)
  taxAmount   Decimal  @default(0)  @db.Decimal(10,2)
  totalAmount Decimal  @db.Decimal(10,2)
  currency    String   @default("EUR")
  // Status
  status      String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  description String?
  periodStart DateTime?
  periodEnd   DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  // Files
  pdfUrl      String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([licenseId, status])
  @@map("license_invoices")
}

