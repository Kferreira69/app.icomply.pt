}

model Dpia {
  id                              String       @id @default(uuid())
  organizationId                  String
  activityId                      String?
  title                           String
  description                     String
  necessityTest                   String?
  proportionalityTest             String?
  riskAssessment                  String?
  mitigationMeasures              String?
  dpoConsultation                 String?
  supervisoryAuthorityConsulted   Boolean      @default(false)
  outcome                         DpiaOutcome?
  status                          DpiaStatus   @default(DRAFT)
  ownerId                         String
  reviewedAt                      DateTime?
  createdAt                       DateTime     @default(now())
  updatedAt                       DateTime     @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id])
  activity     DataProcessingActivity?  @relation(fields: [activityId], references: [id])
  owner        User                     @relation("DpiaOwner", fields: [ownerId], references: [id])

  @@index([organizationId, status])
  @@map("dpias")
}

model BreachNotification {
  id                             String         @id @default(uuid())
  organizationId                 String
  title                          String
  description                    String
  discoveredAt                   DateTime
  affectedDataSubjects           Int?
  affectedDataCategories         String[]       @default([])
  severity                       BreachSeverity @default(MEDIUM)
  status                         BreachStatus   @default(IDENTIFIED)
  supervisoryAuthorityNotifiedAt DateTime?
  supervisoryAuthorityReference  String?
  dataSubjectsNotifiedAt         DateTime?
  containmentMeasures            String?
  rootCause                      String?
  ownerId                        String
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation("BreachNotificationOwner", fields: [ownerId], references: [id])

  @@index([organizationId, status])
  @@map("breach_notifications")
}

// ─── NIS2 Compliance ──────────────────────────────────────────

enum Nis2MeasureStatus {
  NOT_ASSESSED
  NON_COMPLIANT
  PARTIAL
  COMPLIANT
  NOT_APPLICABLE
}

model Nis2Assessment {
  id             String             @id @default(uuid())
  organizationId String
  measureCode    String             // e.g. "ART21_A", "ART23_1"
  category       String             // RISK_MANAGEMENT | INCIDENT_RESPONSE | SUPPLY_CHAIN | BCP | CRYPTOGRAPHY | HR_SECURITY | ACCESS_CONTROL | VULNERABILITY
  title          String
  description    String?
  status         Nis2MeasureStatus  @default(NOT_ASSESSED)
  evidence       String?
  notes          String?
  responsibleId  String?
  targetDate     DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  responsible  User?        @relation("Nis2Responsible", fields: [responsibleId], references: [id])

  @@unique([organizationId, measureCode])
  @@index([organizationId, status])
  @@map("nis2_assessments")
}

// ─── Vendor / Third-Party Risk ────────────────────────────────

enum VendorStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
  TERMINATED
}

enum VendorRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Vendor {
  id              String          @id @default(uuid())
  organizationId  String
  name            String
  category        String          @default("Technology")
  contactName     String?
  contactEmail    String?
  website         String?
  countries       String?
  status          VendorStatus    @default(ACTIVE)
  riskLevel       VendorRiskLevel @default(MEDIUM)
  riskScore       Int?
  contractStart   DateTime?
  contractEnd     DateTime?
  dataProcessor   Boolean         @default(false)
  dataShared      String?
  lastAssessedAt  DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id])
  assessments    VendorAssessment[]
  questionnaires VendorQuestionnaire[]

  @@index([organizationId, status])
  @@index([organizationId, riskLevel])
  @@map("vendors")
}

model VendorAssessment {
  id           String          @id @default(uuid())
  vendorId     String
  score        Int
  riskLevel    VendorRiskLevel @default(MEDIUM)
  findings     String?
  assessedById String
  createdAt    DateTime        @default(now())

  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  assessedBy User   @relation("VendorAssessor", fields: [assessedById], references: [id])

  @@map("vendor_assessments")
}

// ── Vendor public questionnaire ───────────────────────────────

model VendorQuestionnaire {
  id           String   @id @default(uuid())
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  token        String   @unique @default(uuid())
  title        String   @default("Security & Compliance Questionnaire")
  instructions String?
  status       String   @default("PENDING")  // PENDING, COMPLETED, EXPIRED
  expiresAt    DateTime?
  completedAt  DateTime?
  vendorName   String?   // vendor-provided name during submission
  vendorContact String?
  createdById  String?
  responses    VendorQuestionnaireResponse[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vendorId])
  @@map("vendor_questionnaires")
}

model VendorQuestionnaireResponse {
  id               String   @id @default(uuid())
  questionnaireId  String
  questionnaire    VendorQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  sectionKey       String
  questionKey      String
  answer           String?
  score            Int?     // 0-100 for numeric questions
  createdAt        DateTime @default(now())

  @@index([questionnaireId, sectionKey])
  @@map("vendor_questionnaire_responses")
}

// ── Notification preferences ──────────────────────────────────

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // TASK_DUE_SOON, TASK_OVERDUE, RISK_HIGH, CAPA_DUE_SOON, etc.
  inApp       Boolean  @default(true)
  email       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, type])
  @@map("notification_preferences")
}

// ── Audit Templates ───────────────────────────────────────────

model AuditTemplate {
  id             String   @id @default(uuid())
  organizationId String?  // null = global template
  name           String
  type           String   // INTERNAL, EXTERNAL, CERTIFICATION, SURVEILLANCE
  framework      String?  // ISO_27001, GDPR, NIS2, DORA, etc.
  description    String?
  checklistItems Json?    // Array of { id, section, question, required }
  isGlobal       Boolean  @default(false)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([framework])
  @@map("audit_templates")
}

// ── Custom Roles ──────────────────────────────────────────────

model OrgRole {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  permissions    Json?    // { module: 'read'|'write'|'none', ... }
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
  @@map("org_roles")
}

// ── Evidence Versions ─────────────────────────────────────────

model EvidenceVersion {
  id          String   @id @default(uuid())
  evidenceId  String
  evidence    Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  s3Key       String
  s3Url       String?
  fileName    String
  fileSize    Int?
  mimeType    String?
  changeNote  String?
  uploadedById String
