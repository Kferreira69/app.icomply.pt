}

// ── SSO Configuration ─────────────────────────────────────────

model SsoConfig {
  id             String   @id @default(uuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String   // AZURE_AD, GOOGLE_WORKSPACE, OKTA, SAML, OIDC
  clientId       String?
  tenantId       String?
  domain         String?
  isActive       Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("sso_configs")
}

// ─── Statement of Applicability (ISO 27001:2022) ──────────────

enum SoaImplementationStatus {
  NOT_STARTED
  PLANNED
  PARTIALLY_IMPLEMENTED
  IMPLEMENTED
  NOT_APPLICABLE
}

model SoaControl {
  id                  String                  @id @default(uuid())
  organizationId      String
  controlCode         String
  theme               String
  title               String
  description         String?
  applicable          Boolean                 @default(true)
  justification       String?
  status              SoaImplementationStatus @default(NOT_STARTED)
  implementationNotes String?
  owner               String?
  targetDate          DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, controlCode])
  @@index([organizationId, theme])
  @@map("soa_controls")
}

// ─── DORA — Digital Operational Resilience Act ────────────────

enum DoraIncidentSeverity {
  MINOR
  SIGNIFICANT
  MAJOR
}

enum DoraIncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum DoraIncidentCategory {
  AVAILABILITY
  AUTHENTICITY
  INTEGRITY
  CONFIDENTIALITY
  CONTINUITY
}

enum DoraTestType {
  VULNERABILITY_ASSESSMENT
  PENETRATION_TEST
  TLPT
  BUSINESS_CONTINUITY
  SCENARIO_BASED
  GAP_ANALYSIS
}

enum DoraTestStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model DoraIncident {
  id                   String               @id @default(uuid())
  organizationId       String
  title                String
  description          String
  severity             DoraIncidentSeverity
  category             DoraIncidentCategory
  status               DoraIncidentStatus   @default(OPEN)
  affectedSystems      String[]             @default([])
  detectedAt           DateTime
  resolvedAt           DateTime?
  rootCause            String?
  impact               String?
  estimatedLoss        Float?
  // Regulatory reporting timelines
  reportedToRegulator  Boolean              @default(false)
  initialReportAt      DateTime?            // ≤ 4 hours
  intermediaryReportAt DateTime?            // ≤ 72 hours
  finalReportAt        DateTime?            // ≤ 1 month
  regulatoryRef        String?
  reportedById         String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  reportedBy   User         @relation("DoraIncidentReporter", fields: [reportedById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@map("dora_incidents")
}

model DoraTest {
  id                  String         @id @default(uuid())
  organizationId      String
  title               String
  testType            DoraTestType
  status              DoraTestStatus @default(PLANNED)
  scope               String?
  provider            String?
  plannedDate         DateTime
  executedDate        DateTime?
  nextTestDate        DateTime?
  findings            String?
  criticalFindings    Int            @default(0)
  highFindings        Int            @default(0)
  remediationDeadline DateTime?
  remediationStatus   String?
  conductedById       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  conductedBy  User?        @relation("DoraTestConductor", fields: [conductedById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, testType])
  @@map("dora_tests")
}

// ─── Translations (manual overrides for i18n) ────────────────

model TranslationOverride {
  id        String   @id @default(uuid())
  locale    String   // 'pt', 'en', ...
  key       String   // e.g. 'common.save', 'dora.title'
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([locale, key])
  @@index([locale])
  @@map("translation_overrides")
}

// ─────────────────────────────────────────────────────────────
// Canal de Denúncias — RGPC / EU Directive 2019/1937
// Lei 93/2021 | Regime Geral da Prevenção da Corrupção
// ─────────────────────────────────────────────────────────────

enum WhistleblowCategory {
  CORRUPTION
  FRAUD
  BRIBERY
  CONFLICT_OF_INTEREST
  ABUSE_OF_POWER
  EMBEZZLEMENT
  MISUSE_OF_INFORMATION
  DATA_BREACH
  WORKPLACE_HARASSMENT
  SAFETY_VIOLATION
  ENVIRONMENTAL_VIOLATION
  OTHER
}

enum WhistleblowStatus {
  RECEIVED           // Received — 7-day ack clock starts
  ACKNOWLEDGED       // Acknowledged within 7 days (legal requirement)
  UNDER_INVESTIGATION
  CONCLUDED
  UNFOUNDED          // Closed as unfounded
  ARCHIVED
}

enum WhistleblowPersonRole {
  ACCUSED
  WITNESS
  OTHER
}

enum WhistleblowTimelineEvent {
  SUBMITTED
  ACKNOWLEDGED
  ASSIGNED
  STATUS_CHANGED
  NOTE_ADDED
  EVIDENCE_ADDED
  CONCLUDED
  REGULATORY_NOTIFIED
  MENAC_REPORTED
}

// ── Main report ───────────────────────────────────────────────

model WhistleblowReport {
  id               String               @id @default(uuid())
  organizationId   String
  referenceCode    String               @unique // Public: e.g. "DEN-2024-0001"
  secureToken      String               @unique // Private: reporter status-check token
  isAnonymous      Boolean              @default(true)
  category         WhistleblowCategory
  status           WhistleblowStatus    @default(RECEIVED)

  // Reporter info (only if not anonymous)
  reporterName     String?
  reporterEmail    String?
  reporterPhone    String?
  reporterDept     String?
  reporterRelation String?              // EMPLOYEE, CONTRACTOR, SUPPLIER, FORMER_EMPLOYEE, OTHER

  // Incident details
  subject          String
  description      String
  incidentDate     DateTime?
  incidentLocation String?
  repeatOffense    Boolean              @default(false)
  witnesses        String?              // Free text initially

  // Deadlines (Lei 93/2021)
  ackDeadline      DateTime             // +7 days from createdAt
  resolutionDeadline DateTime           // +3 months (extendable to 6)
  deadlineExtended Boolean              @default(false)
  extendedUntil    DateTime?
  extensionReason  String?

  // Timestamps
  acknowledgedAt   DateTime?
  assignedAt       DateTime?
  concludedAt      DateTime?

  // Resolution
  conclusionSummary String?
  conclusionType    String?             // SUBSTANTIATED, UNSUBSTANTIATED, INSUFFICIENT_EVIDENCE
  actionsTaken      String?
  regulatoryNotified Boolean            @default(false)
  regulatoryNotifiedAt DateTime?

  // Internal handling
  assignedToId     String?
  internalNotes    String?              // Protected — not visible to reporter
  assignedTo       User?    @relation("WhistleblowAssignee", fields: [assignedToId], references: [id])
  organization     Organization @relation(fields: [organizationId], references: [id])

  persons          WhistleblowPerson[]
  evidences        WhistleblowEvidence[]
  timeline         WhistleblowTimeline[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([referenceCode])
  @@map("whistleblow_reports")
}

model WhistleblowPerson {
  id          String                @id @default(uuid())
  reportId    String
  role        WhistleblowPersonRole
  name        String?
  jobTitle    String?
  department  String?
  notes       String?
  report      WhistleblowReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("whistleblow_persons")
}

model WhistleblowEvidence {
  id          String   @id @default(uuid())
  reportId    String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  uploadedAt  DateTime @default(now())
  uploadedBy  String?  // null = reporter (anonymous)
  report      WhistleblowReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

