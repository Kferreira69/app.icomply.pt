// ─────────────────────────────────────────────────────────────
// iComply — Prisma Schema  (Phase 1 MVP)
// Owner: Contemporary Constellation
// ─────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COMPLIANCE_MANAGER
  CONSULTANT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLikelihood {
  RARE        // 1
  UNLIKELY    // 2
  POSSIBLE    // 3
  LIKELY      // 4
  ALMOST_CERTAIN // 5
}

enum RiskImpact {
  NEGLIGIBLE  // 1
  MINOR       // 2
  MODERATE    // 3
  MAJOR       // 4
  CATASTROPHIC // 5
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATED
  ACCEPTED
  CLOSED
}

enum EvidenceStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AuditType {
  INTERNAL
  EXTERNAL
  CERTIFICATION
  SURVEILLANCE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FindingSeverity {
  OBSERVATION
  MINOR
  MAJOR
  CRITICAL
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED
  CLOSED
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  OVERDUE
}

enum ControlStatus {
  NOT_APPLICABLE
  NOT_IMPLEMENTED
  PARTIALLY_IMPLEMENTED
  IMPLEMENTED
  VERIFIED
}

enum NotificationType {
  // Tasks
  TASK_ASSIGNED
  TASK_DUE_SOON       // 3 days before due date
  TASK_OVERDUE
  TASK_COMPLETED
  // Risks
  RISK_HIGH           // risk scored HIGH or CRITICAL
  RISK_STATUS_CHANGED
  // CAPA
  CAPA_ASSIGNED
  CAPA_DUE_SOON
  CAPA_OVERDUE
  // Audits
  AUDIT_SCHEDULED
  AUDIT_FINDING_ADDED
  // Evidence
  EVIDENCE_EXPIRING   // 30 days before expiry
  EVIDENCE_REJECTED
  // System
  USER_INVITED
  SYSTEM
}

enum DiagnosticStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ReportType {
  COMPLIANCE_SUMMARY
  RISK_REGISTER
  AUDIT_REPORT
  TASK_STATUS
  EVIDENCE_GAP
  EXECUTIVE_DASHBOARD
}

enum ReportFormat {
  PDF
  EXCEL
  JSON
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PolicyStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

enum PolicyCategory {
  INFORMATION_SECURITY
  DATA_PROTECTION
  BUSINESS_CONTINUITY
  HUMAN_RESOURCES
  PHYSICAL_SECURITY
  ACCESS_CONTROL
  INCIDENT_MANAGEMENT
  SUPPLIER_MANAGEMENT
  COMPLIANCE
  OPERATIONAL
  OTHER
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTERESTS
  PUBLIC_TASK
  LEGITIMATE_INTERESTS
}

enum ProcessingActivityStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
}

enum DpiaStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
}

enum DpiaOutcome {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK_PROCEED
  HIGH_RISK_CONSULT_DPA
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachStatus {
  IDENTIFIED
  ASSESSING
  NOTIFYING
  CLOSED
}

// ─── Organizations (Tenants) ──────────────────────────────────

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  industry     String?  // e.g. TECHNOLOGY, FINANCIAL_SERVICES, HEALTHCARE
  size         String?  // MICRO, SMALL, MEDIUM, LARGE, ENTERPRISE
  country      String   @default("PT")
  vatNumber    String?
  address      String?
  logoUrl      String?
  website      String?
  billingEmail String?
  plan         String   @default("FREE") // FREE, STARTER, PROFESSIONAL, ENTERPRISE
  maxUsers     Int      @default(5)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users             User[]
  projects          Project[]
  risks             Risk[]
  diagnosticRuns    DiagnosticRun[]
  auditLogs         AuditLog[]
  reports           Report[]
  excelImports      ExcelImport[]
  audits            Audit[]
  notifications     Notification[]
  policies          Policy[]
  dataProcessingActivities DataProcessingActivity[]
  dpias             Dpia[]
  breachNotifications BreachNotification[]
  nis2Assessments   Nis2Assessment[]

  @@map("organizations")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?
  firstName        String
  lastName         String
  role             UserRole   @default(VIEWER)
  status           UserStatus @default(INVITED)
  avatarUrl        String?
  phone            String?
  inviteToken      String?    @unique
  inviteExpiresAt  DateTime?
  passwordResetToken String?  @unique
  passwordResetExpiresAt DateTime?
  lastLoginAt      DateTime?
  organizationId   String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])
  assignedTasks    Task[]       @relation("TaskAssignee")
  createdTasks     Task[]       @relation("TaskCreator")
  taskComments     TaskComment[]
  risks            Risk[]
  evidences        Evidence[]
  auditLogs        AuditLog[]
  capaItems        Capa[]       @relation("CapaAssignee")
  createdCapas     Capa[]       @relation("CapaCreator")
  notifications    Notification[]
  auditParticipations AuditParticipant[]
  ownedPolicies    Policy[]     @relation("PolicyOwner")
  approvedPolicies Policy[]     @relation("PolicyApprover")
  policyVersions   PolicyVersion[]
  policyAcknowledgments PolicyAcknowledgment[]
  controlledActivities DataProcessingActivity[] @relation("ProcessingActivityController")
  ownedDpias       Dpia[]       @relation("DpiaOwner")
  ownedBreaches    BreachNotification[] @relation("BreachNotificationOwner")
  nis2Assessments  Nis2Assessment[]     @relation("Nis2Responsible")

  @@map("users")
}

// ─── Frameworks ───────────────────────────────────────────────

model Framework {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique  // e.g. ISO_27001, GDPR, NIS2, RGPC
  version     String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements Requirement[]
  controls     Control[]
  templates    Template[]
  projects     Project[]
  diagnosticQuestions DiagnosticQuestion[]
  policies     Policy[]

  @@map("frameworks")
}

// ─── Requirements (framework clauses) ────────────────────────

model Requirement {
  id           String   @id @default(uuid())
  frameworkId  String
  code         String   // e.g. "6.1.2", "Art. 5"
  title        String
  description  String?
  category     String?
  mandatory    Boolean  @default(true)
  sortOrder    Int      @default(0)
  parentId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  framework    Framework    @relation(fields: [frameworkId], references: [id])
  parent       Requirement? @relation("RequirementHierarchy", fields: [parentId], references: [id])
  children     Requirement[] @relation("RequirementHierarchy")
  controls     Control[]

  @@unique([frameworkId, code])
  @@map("requirements")
}

// ─── Controls ─────────────────────────────────────────────────

model Control {
  id            String        @id @default(uuid())
  frameworkId   String
  requirementId String?
  code          String
  title         String
  description   String?
  guidance      String?
  category      String?
  status        ControlStatus @default(NOT_IMPLEMENTED)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  framework    Framework    @relation(fields: [frameworkId], references: [id])
  requirement  Requirement? @relation(fields: [requirementId], references: [id])
  tasks        Task[]
  evidences    Evidence[]
  findings     Finding[]

  @@unique([frameworkId, code])
  @@map("controls")
}

// ─── Templates ───────────────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  frameworkId String
  name        String
  description String?
  type        String   // PROJECT, TASK_LIST, REPORT, etc.
  content     Json     // template structure
  isPublic    Boolean  @default(true)
  version     String   @default("1.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  framework   Framework @relation(fields: [frameworkId], references: [id])
  projects    Project[]

  @@map("templates")
}

// ─── Diagnostic Engine ────────────────────────────────────────

model DiagnosticQuestion {
  id           String   @id @default(uuid())
  frameworkId  String?
  code         String   @unique
  question     String
  description  String?
  category     String
  type         String   // SINGLE_CHOICE, MULTIPLE_CHOICE, SCALE, TEXT, BOOLEAN
  options      Json?    // [{value, label, weight}]
  weight       Float    @default(1.0)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  conditionalOn String? // JSON: {questionCode, value}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  framework    Framework? @relation(fields: [frameworkId], references: [id])
  answers      DiagnosticAnswer[]

  @@map("diagnostic_questions")
}

model DiagnosticRun {
  id              String           @id @default(uuid())
  organizationId  String
  status          DiagnosticStatus @default(IN_PROGRESS)
  answers         DiagnosticAnswer[]
  recommendations Json?            // [{frameworkId, score, priority, reason}]
  sector          String?
  country         String?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  projects     Project[]

  @@map("diagnostic_runs")
}

model DiagnosticAnswer {
  id          String   @id @default(uuid())
  runId       String
  questionId  String
  value       Json     // the answer value(s)
  score       Float?
  createdAt   DateTime @default(now())

  run         DiagnosticRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  question    DiagnosticQuestion @relation(fields: [questionId], references: [id])

  @@unique([runId, questionId])
  @@map("diagnostic_answers")
}

// ─── Projects ─────────────────────────────────────────────────

model Project {
  id               String        @id @default(uuid())
  organizationId   String
  frameworkId      String
  templateId       String?
  diagnosticRunId  String?
  name             String
  description      String?
  status           ProjectStatus @default(DRAFT)
  complianceScore  Float?        // 0-100
  startDate        DateTime?
  targetDate       DateTime?
  completedAt      DateTime?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  framework     Framework     @relation(fields: [frameworkId], references: [id])
  template      Template?     @relation(fields: [templateId], references: [id])
  diagnosticRun DiagnosticRun? @relation(fields: [diagnosticRunId], references: [id])
  tasks         Task[]
  risks         Risk[]
  audits        Audit[]
  evidences     Evidence[]
  reports       Report[]

  @@map("projects")
}

// ─── Tasks ────────────────────────────────────────────────────

model Task {
  id             String       @id @default(uuid())
  projectId      String
  controlId      String?
  assigneeId     String?
  createdById    String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?
  tags           String[]
  sortOrder      Int          @default(0)
  parentId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  control    Control? @relation(fields: [controlId], references: [id])
  assignee   User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy  User     @relation("TaskCreator", fields: [createdById], references: [id])
  parent     Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  subtasks   Task[]   @relation("TaskHierarchy")
  evidences  Evidence[]
  comments   TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

// ─── Risks ────────────────────────────────────────────────────

model Risk {
  id              String         @id @default(uuid())
  organizationId  String
  projectId       String?
  ownerId         String?
  title           String
  description     String?
  category        String?
  likelihood      RiskLikelihood @default(POSSIBLE)
  impact          RiskImpact     @default(MODERATE)
  inherentScore   Int            // likelihood * impact (1-25)
  residualScore   Int?           // after controls
  status          RiskStatus     @default(IDENTIFIED)
  mitigationPlan  String?
  acceptancePlan  String?
  dueDate         DateTime?
  reviewDate      DateTime?
  closedAt        DateTime?
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  owner        User?        @relation(fields: [ownerId], references: [id])
  evidences    Evidence[]

  @@map("risks")
}

// ─── Evidence ─────────────────────────────────────────────────

model Evidence {
  id              String         @id @default(uuid())
  projectId       String?
  taskId          String?
  controlId       String?
  riskId          String?
  uploadedById    String
  title           String
  description     String?
  fileName        String
  fileSize        Int
  mimeType        String
  s3Key           String         // S3 object key
  s3Url           String?        // pre-signed or public URL
  version         Int            @default(1)
  previousVersion String?        // previous evidence id
  status          EvidenceStatus @default(PENDING)
  expiresAt       DateTime?
  reviewedAt      DateTime?
  tags            String[]
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project    Project?  @relation(fields: [projectId], references: [id])
  task       Task?     @relation(fields: [taskId], references: [id])
  control    Control?  @relation(fields: [controlId], references: [id])
  risk       Risk?     @relation(fields: [riskId], references: [id])
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@map("evidences")
}

// ─── Audits ───────────────────────────────────────────────────

model Audit {
  id             String      @id @default(uuid())
  organizationId String
  projectId      String?
  title          String
  type           AuditType   @default(INTERNAL)
  status         AuditStatus @default(PLANNED)
  scope          String?
  objectives     String?
  startDate      DateTime?
  endDate        DateTime?
  completedAt    DateTime?
  leadAuditor    String?
  summary        String?
  score          Float?      // 0-100
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  project      Project?          @relation(fields: [projectId], references: [id])
  participants AuditParticipant[]
  findings     Finding[]

  @@map("audits")
}

model AuditParticipant {
  id        String @id @default(uuid())
  auditId   String
  userId    String
  role      String // LEAD_AUDITOR, AUDITOR, AUDITEE, OBSERVER

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([auditId, userId])
  @@map("audit_participants")
}

// ─── Findings ─────────────────────────────────────────────────

model Finding {
  id          String          @id @default(uuid())
  auditId     String
  controlId   String?
  title       String
  description String
  severity    FindingSeverity @default(MINOR)
  status      FindingStatus   @default(OPEN)
  evidence    String?
  requirement String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  audit   Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  control Control? @relation(fields: [controlId], references: [id])
  capas   Capa[]

  @@map("findings")
}

// ─── CAPA (Corrective and Preventive Actions) ─────────────────

model Capa {
  id           String     @id @default(uuid())
  findingId    String?
  assigneeId   String?
  createdById  String
  title        String
  description  String
  rootCause    String?
  correctiveAction String?
  preventiveAction String?
  status       CapaStatus @default(OPEN)
  dueDate      DateTime?
  verifiedAt   DateTime?
  closedAt     DateTime?
  evidence     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  finding    Finding? @relation(fields: [findingId], references: [id])
  assignee   User?    @relation("CapaAssignee", fields: [assigneeId], references: [id])
  createdBy  User     @relation("CapaCreator", fields: [createdById], references: [id])

  @@map("capas")
}

// ─── Reports ─────────────────────────────────────────────────

model Report {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String?
  type           ReportType
  format         ReportFormat @default(PDF)
  name           String
  parameters     Json?        // filter params
  s3Key          String?      // generated file
  s3Url          String?
  generatedAt    DateTime?
  status         String       @default("PENDING") // PENDING, READY, FAILED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@map("reports")
}

// ─── Excel Imports ───────────────────────────────────────────

model ExcelImport {
  id             String       @id @default(uuid())
  organizationId String
  fileName       String
  fileSize       Int
  s3Key          String
  type           String       // TASKS, RISKS, CONTROLS, GENERIC
  status         ImportStatus @default(PENDING)
  mapping        Json?        // column mapping
  rowsTotal      Int?
  rowsProcessed  Int?
  rowsError      Int?
  errors         Json?
  result         Json?        // summary of what was created
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("excel_imports")
}

// ─── Audit Logs ───────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  action         String   // CREATE, UPDATE, DELETE, LOGIN, EXPORT, etc.
  entity         String   // Organization, User, Project, Risk, etc.
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  organizationId String
  userId         String           // recipient
  type           NotificationType
  title          String
  message        String
  entityType     String?          // "Task" | "Risk" | "Capa" | etc.
  entityId       String?          // uuid of the related entity
  read           Boolean          @default(false)
  readAt         DateTime?
  emailSent      Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([organizationId, createdAt])
  @@map("notifications")
}

// ─── Policies ─────────────────────────────────────────────────

model Policy {
  id             String         @id @default(uuid())
  organizationId String
  title          String
  description    String?
  content        String         @db.Text
  version        String         @default("1.0")
  status         PolicyStatus   @default(DRAFT)
  category       PolicyCategory @default(OTHER)
  frameworkId    String?
  ownerId        String
  approverId     String?
  approvedAt     DateTime?
  effectiveDate  DateTime?
  reviewDate     DateTime?
  expiresAt      DateTime?
  tags           String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization           @relation(fields: [organizationId], references: [id])
  owner           User                   @relation("PolicyOwner", fields: [ownerId], references: [id])
  approver        User?                  @relation("PolicyApprover", fields: [approverId], references: [id])
  framework       Framework?             @relation(fields: [frameworkId], references: [id])
  versions        PolicyVersion[]
  acknowledgments PolicyAcknowledgment[]

  @@index([organizationId, status])
  @@index([organizationId, category])
  @@map("policies")
}

model PolicyVersion {
  id          String   @id @default(uuid())
  policyId    String
  version     String
  content     String   @db.Text
  changeNote  String?
  changedById String
  createdAt   DateTime @default(now())

  policy    Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@map("policy_versions")
}

model PolicyAcknowledgment {
  id             String   @id @default(uuid())
  policyId       String
  userId         String
  policyVersion  String?
  acknowledgedAt DateTime @default(now())
  ipAddress      String?

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([policyId, userId])
  @@map("policy_acknowledgments")
}

// ─── GDPR / Data Protection ────────────────────────────────────

model DataProcessingActivity {
  id                     String                   @id @default(uuid())
  organizationId         String
  name                   String
  purpose                String
  legalBasis             LegalBasis
  dataCategories         String[]                 @default([])
  dataSubjects           String[]                 @default([])
  recipients             String[]                 @default([])
  internationalTransfers Boolean                  @default(false)
  transferCountries      String[]                 @default([])
  transferSafeguards     String?
  retentionPeriod        String
  retentionJustification String?
  technicalMeasures      String[]                 @default([])
  organizationalMeasures String[]                 @default([])
  dpoConsulted           Boolean                  @default(false)
  processorName          String?
  processorCountry       String?
  status                 ProcessingActivityStatus @default(ACTIVE)
  controllerId           String
  reviewDate             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  controller   User         @relation("ProcessingActivityController", fields: [controllerId], references: [id])
  dpias        Dpia[]

  @@index([organizationId, status])
  @@map("data_processing_activities")
}

model Dpia {
  id                              String       @id @default(uuid())
  organizationId                  String
  activityId                      String?
  title                           String
  description                     String
  necessityTest                   String?
  proportionalityTest             String?
  riskAssessment                  String?
  mitigationMeasures              String?
  dpoConsultation                 String?
  supervisoryAuthorityConsulted   Boolean      @default(false)
  outcome                         DpiaOutcome?
  status                          DpiaStatus   @default(DRAFT)
  ownerId                         String
  reviewedAt                      DateTime?
  createdAt                       DateTime     @default(now())
  updatedAt                       DateTime     @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id])
  activity     DataProcessingActivity?  @relation(fields: [activityId], references: [id])
  owner        User                     @relation("DpiaOwner", fields: [ownerId], references: [id])

  @@index([organizationId, status])
  @@map("dpias")
}

model BreachNotification {
  id                             String         @id @default(uuid())
  organizationId                 String
  title                          String
  description                    String
  discoveredAt                   DateTime
  affectedDataSubjects           Int?
  affectedDataCategories         String[]       @default([])
  severity                       BreachSeverity @default(MEDIUM)
  status                         BreachStatus   @default(IDENTIFIED)
  supervisoryAuthorityNotifiedAt DateTime?
  supervisoryAuthorityReference  String?
  dataSubjectsNotifiedAt         DateTime?
  containmentMeasures            String?
  rootCause                      String?
  ownerId                        String
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation("BreachNotificationOwner", fields: [ownerId], references: [id])

  @@index([organizationId, status])
  @@map("breach_notifications")
}

// ─── NIS2 Compliance ──────────────────────────────────────────

enum Nis2MeasureStatus {
  NOT_ASSESSED
  NON_COMPLIANT
  PARTIAL
  COMPLIANT
  NOT_APPLICABLE
}

model Nis2Assessment {
  id             String             @id @default(uuid())
  organizationId String
  measureCode    String             // e.g. "ART21_A", "ART23_1"
  category       String             // RISK_MANAGEMENT | INCIDENT_RESPONSE | SUPPLY_CHAIN | BCP | CRYPTOGRAPHY | HR_SECURITY | ACCESS_CONTROL | VULNERABILITY
  title          String
  description    String?
  status         Nis2MeasureStatus  @default(NOT_ASSESSED)
  evidence       String?
  notes          String?
  responsibleId  String?
  targetDate     DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  responsible  User?        @relation("Nis2Responsible", fields: [responsibleId], references: [id])

  @@unique([organizationId, measureCode])
  @@index([organizationId, status])
  @@map("nis2_assessments")
}
