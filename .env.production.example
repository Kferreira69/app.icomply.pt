# ─────────────────────────────────────────────────────────────────────────────
# iComply — Production Environment Variables
# Copy to .env.production and fill in real values. NEVER commit this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ───────────────────────────────────────────────────
# The main domain for iComply (e.g. app.icomply.pt)
# Backend will be available at api.${DOMAIN}
DOMAIN=app.icomply.pt

# ── Image tag ────────────────────────────────────────────────
IMAGE_TAG=latest

# ── Database ─────────────────────────────────────────────────
DB_USER=icomply
DB_PASSWORD=CHANGE_ME_strong_db_password_here
DB_NAME=icomply_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ── MinIO / S3 ───────────────────────────────────────────────
MINIO_USER=icomply_minio_admin
MINIO_PASSWORD=CHANGE_ME_strong_minio_password_here
S3_BUCKET=icomply-evidence
S3_REGION=eu-west-1

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64_different
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@icomply.pt
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM="iComply <noreply@icomply.pt>"

# ── Traefik / Let's Encrypt ───────────────────────────────────
TRAEFIK_ACME_EMAIL=ops@contemporaryconstellation.pt

# ── Feature Flags ────────────────────────────────────────────
ENABLE_SWAGGER=false
ENABLE_AUDIT_LOG=true
